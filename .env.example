# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Circle
CIRCLE_API_KEY=your-circle-api-key
CIRCLE_ENTITY_SECRET=your-circle-entity-secret

# Public HTTPS URL Circle posts Gateway webhooks to. Must be reachable from the
# internet, so local dev needs a tunnel (e.g. ngrok) or a deployed URL. Used to
# create/sync the Gateway permissionless webhook subscription. If unset, the app
# falls back to `${NEXT_PUBLIC_APP_URL}/api/circle/webhook`; if neither is set,
# webhook registration is skipped (handler still works once events arrive).
WEBHOOK_ENDPOINT_URL=https://finch-aware-toucan.ngrok-free.app/api/circle/webhook

# Optional: dedicated endpoint for the Gateway *permissionless* webhook
# subscription. Circle requires a unique endpoint URL per subscription, so the
# Gateway subscription cannot reuse WEBHOOK_ENDPOINT_URL (used by the standard
# DCW subscription). If unset, it is derived by swapping the path of
# WEBHOOK_ENDPOINT_URL (or NEXT_PUBLIC_APP_URL) to `/api/circle/gateway-webhook`,
# which routes to the same handler. Set this only to override that default.
# GATEWAY_WEBHOOK_ENDPOINT_URL=

# Arc Testnet RPC (server-side only). Required for any Arc Testnet RPC reads
# (USDC balance lookups, etc.). Without it, requests fall back to the public
# RPC URL which is rate-limited.
ARC_TESTNET_RPC_KEY=
